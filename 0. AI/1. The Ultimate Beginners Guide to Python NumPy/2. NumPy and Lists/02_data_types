
import numpy as np

list_a = [1, 3.5, 'a', True]

# print(type(list_a))

for e in list_a:
    print(type(e))


# NumPy - convert all elements type to the most general data type
print("-------------NumPy------------")
array_a = np.array(list_a)
# print(type(list_a))

for e in array_a:
    print(type(e))

print("------------------------")

array_b = np.array([1, 2, 3, 4, 5])

for e in array_b:
    print(type(e))


# dtype: shows the data type of the array stores
print(array_b.dtype)

